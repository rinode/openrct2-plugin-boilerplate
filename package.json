  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/cli": "^7.24.0",
    "@rollup/plugin-json": "^6.1.0",
    "rollup": "^4.13.0",
    "cpy-cli": "^5.0.0",
    "npm-watch": "^0.13.0"
  },
  "dependencies": {}
